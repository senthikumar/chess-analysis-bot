# Chess Analysis Bot — Environment Variables
# Copy this file to .env and fill in your credentials
# Never commit .env to version control

# Anthropic (Claude)
# Get from: console.anthropic.com → API Keys
# New accounts receive $5 free credit — no credit card needed
ANTHROPIC_API_KEY=sk-ant-...

# Groq (Llama 3.3 70B)
# Get from: console.groq.com → API Keys
# Free tier: generous daily limits, sufficient for prototyping
GROQ_API_KEY=gsk_...

# Twilio WhatsApp
# Get from: console.twilio.com → Account Info
# Sandbox is free for testing — no payment needed
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# n8n Webhook (set after deploying workflow)
# Production URL (no -test suffix) for always-on operation
N8N_WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook/chess
